FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=another-long-random-string-for-jwt

# SQLite pour dev, PostgreSQL pour prod
DATABASE_URL=sqlite:///parallax.db
# DATABASE_URL=postgresql://user:password@localhost:5432/parallax_db

# Stockage des projets sur le noeud local
STORAGE_ROOT=./storage/projects

# Quota de stockage par utilisateur (octets)
MAX_STORAGE_PER_USER=1073741824

# CORS - origines autorisées (séparées par virgule)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Clé API interne pour les noeuds du cluster
CLUSTER_INTERNAL_KEY=internal-cluster-secret-key

# Adresse IP du noeud maître (ce serveur)
MASTER_NODE_IP=192.168.1.1
